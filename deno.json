{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run --watch src/main.ts",
    "build": ""
  },
  "fmt": {
    "useTabs": false,
    "semiColons": true,
    "bracePosition": "sameLine",
    "singleQuote": true,
    "useBraces": "preferNone"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "effect": "npm:effect@^4.0.0-beta.74",
    "fast-xml-parser": "npm:fast-xml-parser@^5.8.0",
    "hono": "npm:hono@^4.12.23"
  },
  "allowScripts": ["npm:msgpackr-extract@3.0.4"]
}
